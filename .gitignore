```bash
# Ignore patterns for git.
# See:  https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Python Distribution Artifacts
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Don't track IDE stuff (Jetbrains, Fleet, VS Code)
.idea/
.fleet/
.vscode/
.zed/

# Don't track .DS_Store (Mac Temp file)
.DS_Store

# Ignore Zone.Identifier files (created by Windows when downloading files)
*:Zone.Identifier

# Don't track __pycache__ folders
*__pycache__

# Don't track virtual environment subdirectories
virtualenv/
.venv/
venv/

# Ignore .env, which may hold sensitive variables / secrets
.env

# Working notes (local only)
TODO.md

# Ignore jupyter artifacts
.ipynb
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
```
